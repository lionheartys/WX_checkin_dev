/* pages/leave/leave.wxss */
.leave-page {
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  /* 标签栏 */
  .tabs {
    display: flex;
    background: white;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .tab-item {
    flex: 1;
    padding: 30rpx 0;
    text-align: center;
    position: relative;
    transition: all 0.3s ease;
  }
  
  .tab-item text {
    font-size: 30rpx;
    color: #666;
    transition: all 0.3s ease;
  }
  
  .tab-item.active text {
    color: #667eea;
    font-weight: 600;
  }
  
  .tab-item.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20%;
    right: 20%;
    height: 4rpx;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    border-radius: 2rpx;
  }
  
  /* 内容区域 */
  .tab-content {
    padding: 20rpx;
    animation: fadeIn 0.3s ease;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10rpx);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* 表单卡片 */
  .form-card {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  }
  
  .form-item {
    padding: 30rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .form-item:last-child {
    border-bottom: none;
  }
  
  .form-label {
    display: block;
    font-size: 28rpx;
    color: #999;
    margin-bottom: 20rpx;
  }
  
  .picker-value {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    font-size: 30rpx;
    color: #333;
  }
  
  .arrow {
    color: #999;
    font-size: 28rpx;
  }
  
  .form-value {
    padding: 20rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    display: flex;
    align-items: baseline;
  }
  
  .days-count {
    font-size: 40rpx;
    font-weight: bold;
    color: #667eea;
    margin-right: 10rpx;
  }
  
  .days-unit {
    font-size: 28rpx;
    color: #666;
  }
  
  .reason-input {
    width: 100%;
    min-height: 200rpx;
    padding: 20rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    font-size: 30rpx;
    color: #333;
    box-sizing: border-box;
  }
  
  /* 提示信息 */
  .tips {
    margin-top: 20rpx;
    padding: 20rpx;
    background: #fff3cd;
    border-radius: 12rpx;
  }
  
  .tips text {
    font-size: 26rpx;
    color: #856404;
  }
  
  /* 提交按钮 */
  .submit-btn {
    margin-top: 40rpx;
    height: 90rpx;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    font-size: 32rpx;
    font-weight: 600;
    border-radius: 45rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
  }
  
  .submit-btn:active {
    transform: scale(0.98);
  }
  
  .submit-btn[disabled] {
    background: #ccc;
    box-shadow: none;
  }
  
  /* 请假历史 */
  .history-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }
  
  .history-item {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }
  
  .history-item:active {
    transform: scale(0.98);
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
  }
  
  .history-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .history-type {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
  
  .history-status {
    padding: 8rpx 20rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
  }
  
  .history-status.pending {
    background: #fff3cd;
    color: #856404;
  }
  
  .history-status.approved {
    background: #d4edda;
    color: #155724;
  }
  
  .history-status.rejected {
    background: #f8d7da;
    color: #721c24;
  }
  
  .history-status.cancelled {
    background: #e2e3e5;
    color: #383d41;
  }
  
  .history-content {
    padding: 20rpx 0;
    border-top: 1rpx solid #f0f0f0;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .history-date,
  .history-days,
  .history-reason {
    display: flex;
    margin-bottom: 16rpx;
    font-size: 28rpx;
  }
  
  .history-reason {
    margin-bottom: 0;
  }
  
  .history-content .label {
    color: #999;
    margin-right: 20rpx;
    flex-shrink: 0;
  }
  
  .reason-text {
    color: #333;
    flex: 1;
  }
  
  .history-footer {
    margin-top: 20rpx;
  }
  
  .create-time {
    font-size: 24rpx;
    color: #999;
  }
  
  /* 调休额度 */
  .quota-card {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  }
  
  .quota-header {
    text-align: center;
    margin-bottom: 40rpx;
  }
  
  .quota-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .quota-stats {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 40rpx 0;
    background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
    border-radius: 16rpx;
    margin-bottom: 40rpx;
  }
  
  .quota-item {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16rpx;
  }
  
  .quota-value {
    font-size: 48rpx;
    font-weight: bold;
    color: #667eea;
  }
  
  .quota-value.used {
    color: #f5576c;
  }
  
  .quota-value.available {
    color: #28a745;
  }
  
  .quota-label {
    font-size: 26rpx;
    color: #666;
  }
  
  .quota-divider {
    width: 1rpx;
    height: 80rpx;
    background: #e0e0e0;
  }
  
  .apply-quota-btn {
    width: 100%;
    height: 90rpx;
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    color: white;
    font-size: 32rpx;
    font-weight: 600;
    border-radius: 45rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 40rpx;
    box-shadow: 0 8rpx 30rpx rgba(79, 172, 254, 0.3);
  }
  
  .apply-quota-btn:active {
    transform: scale(0.98);
  }
  
  .quota-rules {
    padding: 30rpx;
    background: #f8f9fa;
    border-radius: 16rpx;
  }
  
  .rules-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 20rpx;
  }
  
  .rules-content {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
  }
  
  .rules-content text {
    font-size: 26rpx;
    color: #666;
    line-height: 1.6;
  }
  
  /* 空状态 */
  .empty-container {
    padding: 200rpx 0;
    text-align: center;
  }
  
  .empty-icon {
    font-size: 120rpx;
    margin-bottom: 30rpx;
  }
  
  .empty-text {
    font-size: 30rpx;
    color: #999;
  }
  
  /* 弹窗 */
  .modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
  }
  
  .modal-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 600rpx;
    background: white;
    border-radius: 20rpx;
    z-index: 1000;
    animation: scaleIn 0.3s ease;
  }
  
  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .modal-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
  
  .modal-close {
    font-size: 48rpx;
    color: #999;
    line-height: 1;
    padding: 0 10rpx;
  }
  
  .modal-body {
    padding: 30rpx;
  }
  
  .modal-form-item {
    margin-bottom: 30rpx;
  }
  
  .modal-label {
    display: block;
    font-size: 28rpx;
    color: #666;
    margin-bottom: 16rpx;
  }
  
  .modal-picker-value {
    padding: 20rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    font-size: 30rpx;
    color: #333;
  }
  
  .modal-value {
    padding: 20rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
    font-size: 30rpx;
  }
  
  .modal-value .valid {
    color: #28a745;
    font-weight: 600;
  }
  
  .modal-value .invalid {
    color: #dc3545;
  }
  
  .quota-days {
    color: #667eea;
    font-weight: 600;
  }
  
  .modal-tips {
    padding: 20rpx;
    background: #fff3cd;
    border-radius: 12rpx;
    margin-top: 20rpx;
  }
  
  .modal-tips text {
    font-size: 26rpx;
    color: #856404;
  }
  
  .modal-footer {
    display: flex;
    gap: 20rpx;
    padding: 30rpx;
    border-top: 1rpx solid #f0f0f0;
  }
  
  .modal-btn {
    flex: 1;
    height: 80rpx;
    border-radius: 40rpx;
    font-size: 30rpx;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-btn.cancel {
    background: #f5f5f5;
    color: #666;
  }
  
  .modal-btn.confirm {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }
  
  .modal-btn.confirm[disabled] {
    background: #ccc;
    color: white;
  }