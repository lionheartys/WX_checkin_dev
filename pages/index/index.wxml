<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <text class="username">{{userInfo.username}}</text>
      <text class="role">{{roleText}}</text>
    </view>
    <view class="today-status">
      <text class="date">{{currentDate}}</text>
      <text class="status {{checkinStatus.class}}">{{checkinStatus.text}}</text>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goToCheckin">
      <view class="action-icon checkin"></view>
      <text class="action-text">打卡</text>
    </view>
    <view class="action-item" bindtap="goToHistory">
      <view class="action-icon history"></view>
      <text class="action-text">记录</text>
    </view>
    <view class="action-item" bindtap="goToLeave">
      <view class="action-icon leave"></view>
      <text class="action-text">请假</text>
    </view>
  </view>

  <!-- 今日打卡记录 -->
  <view class="today-records">
    <view class="section-title">今日打卡</view>
    <view class="records-list">
      <view class="record-item" wx:for="{{todayRecords}}" wx:key="id">
        <view class="record-type {{item.checkin_type}}">
          {{item.checkin_type === 'in' ? '上班' : '下班'}}
        </view>
        <view class="record-time">{{item.time}}</view>
        <view class="record-status {{item.checkin_status}}">
          {{item.statusText}}
        </view>
      </view>
      <view class="no-records" wx:if="{{todayRecords.length === 0}}">
        今日暂无打卡记录
      </view>
    </view>
  </view>
</view>