.container {
    background: #f5f5f5;
    min-height: 100vh;
    padding: 30rpx;
  }
  
  .user-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 20rpx;
    padding: 40rpx 30rpx;
    margin-bottom: 30rpx;
    color: #fff;
    box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
  }
  
  .avatar-section {
    display: flex;
    align-items: center;
    gap: 30rpx;
  }
  
  .avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 60rpx;
    background: rgba(255, 255, 255, 0.2);
  }
  
  .username {
    font-size: 42rpx;
    font-weight: bold;
    display: block;
    margin-bottom: 10rpx;
  }
  
  .role {
    font-size: 26rpx;
    opacity: 0.8;
    display: block;
    margin-bottom: 10rpx;
  }
  
  .phone {
    font-size: 28rpx;
    opacity: 0.9;
  }
  
  .stats-card {
    background: #fff;
    border-radius: 20rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  }
  
  .stats-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 30rpx;
  }
  
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30rpx;
  }
  
  .stat-item {
    text-align: center;
    padding: 20rpx;
    background: #f8f9fa;
    border-radius: 12rpx;
  }
  
  .stat-number {
    display: block;
    font-size: 48rpx;
    font-weight: bold;
    color: #1890ff;
    margin-bottom: 10rpx;
  }
  
  .stat-label {
    font-size: 24rpx;
    color: #666;
  }
  
  .menu-section {
    background: #fff;
    border-radius: 20rpx;
    overflow: hidden;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  }
  
  .menu-item {
    padding: 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1rpx solid #f0f0f0;
    background: #fff;
  }
  
  .menu-item:last-child {
    border-bottom: none;
  }
  
  .menu-item:active {
    background: #f8f9fa;
  }
  
  .menu-left {
    display: flex;
    align-items: center;
    gap: 20rpx;
  }
  
  .menu-icon {
    width: 40rpx;
    height: 40rpx;
    border-radius: 8rpx;
  }
  
  .menu-icon.settings {
    background: #1890ff;
  }
  
  .menu-icon.help {
    background: #52c41a;
  }
  
  .menu-icon.about {
    background: #faad14;
  }
  
  .menu-text {
    font-size: 30rpx;
    color: #333;
  }
  
  .menu-arrow {
    font-size: 32rpx;
    color: #999;
  }
  
  .logout-section {
    margin-bottom: 40rpx;
  }
  
  .logout-btn {
    width: 100%;
    height: 90rpx;
    background: #fff;
    color: #f5222d;
    border: 1rpx solid #f5222d;
    border-radius: 45rpx;
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .logout-btn:active {
    background: #f5222d;
    color: #fff;
  }
  
  .version-info {
    text-align: center;
    padding: 20rpx 0;
  }
  
  .version-text {
    font-size: 24rpx;
    color: #999;
  }