.statistics-page {
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  .header {
    background: #1890ff;
    color: white;
    padding: 30rpx;
    text-align: center;
  }
  
  .title {
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .date-selector {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30rpx;
    background: white;
    margin-bottom: 20rpx;
  }
  
  .date-item {
    padding: 15rpx 30rpx;
    background: #f0f0f0;
    border-radius: 8rpx;
    font-size: 28rpx;
  }
  
  .date-separator {
    margin: 0 20rpx;
    color: #999;
  }
  
  .overview-section,
  .attendance-section,
  .department-section {
    background: white;
    margin-bottom: 20rpx;
    padding: 30rpx;
  }
  
  .section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    display: block;
    margin-bottom: 30rpx;
  }
  
  .overview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20rpx;
  }
  
  .overview-item {
    text-align: center;
    padding: 30rpx 0;
    background: #f9f9f9;
    border-radius: 12rpx;
  }
  
  .overview-value {
    display: block;
    font-size: 48rpx;
    font-weight: bold;
    color: #1890ff;
    margin-bottom: 10rpx;
  }
  
  .overview-label {
    font-size: 26rpx;
    color: #666;
  }
  
  .attendance-chart {
    display: flex;
    justify-content: space-around;
    align-items: flex-end;
    height: 300rpx;
    padding: 20rpx;
  }
  
  .chart-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }
  
  .chart-bar {
    width: 80rpx;
    background: linear-gradient(to top, #1890ff, #40a9ff);
    border-radius: 8rpx 8rpx 0 0;
    margin-bottom: 20rpx;
  }
  
  .chart-label {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 10rpx;
  }
  
  .chart-value {
    font-size: 32rpx;
    font-weight: bold;
    color: #1890ff;
  }
  
  .department-list {
    padding: 20rpx 0;
  }
  
  .department-item {
    display: flex;
    align-items: center;
    padding: 20rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .dept-rank {
    width: 60rpx;
    height: 60rpx;
    background: #1890ff;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    font-weight: bold;
  }
  
  .dept-name {
    flex: 1;
    margin-left: 30rpx;
    font-size: 30rpx;
    color: #333;
  }
  
  .dept-rate {
    font-size: 32rpx;
    font-weight: bold;
    color: #52c41a;
  }
  
  .export-section {
    padding: 40rpx;
  }
  
  .export-btn {
    width: 100%;
    height: 88rpx;
    background: #1890ff;
    color: white;
    border-radius: 12rpx;
    font-size: 32rpx;
    font-weight: bold;
  }