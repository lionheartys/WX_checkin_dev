.checkin-records {
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  .header {
    background: #1890ff;
    color: white;
    padding: 30rpx;
    text-align: center;
  }
  
  .title {
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .filter-bar {
    display: flex;
    background: white;
    padding: 20rpx;
    border-bottom: 1rpx solid #e8e8e8;
  }
  
  .filter-item {
    flex: 1;
    padding: 15rpx 20rpx;
    margin: 0 10rpx;
    background: #f5f5f5;
    border-radius: 8rpx;
    text-align: center;
    font-size: 28rpx;
  }
  
  .record-list {
    padding: 20rpx;
  }
  
  .record-card {
    background: white;
    border-radius: 12rpx;
    padding: 25rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  }
  
  .record-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .username {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .status {
    padding: 8rpx 16rpx;
    border-radius: 8rpx;
    font-size: 24rpx;
  }
  
  .status-normal {
    background: #f6ffed;
    color: #52c41a;
  }
  
  .status-late {
    background: #fff7e6;
    color: #fa8c16;
  }
  
  .status-early {
    background: #fff1f0;
    color: #ff4d4f;
  }
  
  .status-absent {
    background: #f0f0f0;
    color: #999;
  }
  
  .info-row {
    display: flex;
    margin-bottom: 12rpx;
  }
  
  .label {
    color: #999;
    width: 140rpx;
    font-size: 26rpx;
  }
  
  .value {
    color: #333;
    flex: 1;
    font-size: 26rpx;
  }
  
  .empty {
    padding: 100rpx;
    text-align: center;
    color: #999;
  }