/* pages/admin/leaveAudit/leaveAudit.wxss */
.leave-audit-page {
    min-height: 100vh;
    background-color: #f5f5f5;
  }
  
  /* 页面头部 */
  .page-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 30rpx;
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .page-title {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .batch-btn {
    background: rgba(255, 255, 255, 0.2) !important;
    color: white !important;
    border: 1rpx solid rgba(255, 255, 255, 0.3) !important;
    padding: 0 24rpx !important;
    height: 60rpx !important;
    line-height: 60rpx !important;
    font-size: 28rpx !important;
  }
  
  .batch-btn:active {
    background: rgba(255, 255, 255, 0.3) !important;
  }
  
  /* 标签栏 */
  .tabs {
    display: flex;
    background: white;
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .tab-item {
    flex: 1;
    padding: 30rpx 20rpx;
    text-align: center;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10rpx;
  }
  
  .tab-item.active {
    color: #667eea;
  }
  
  .tab-item.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20%;
    right: 20%;
    height: 4rpx;
    background: #667eea;
  }
  
  .tab-count {
    font-size: 24rpx;
    color: #999;
  }
  
  .tab-item.active .tab-count {
    color: #667eea;
  }
  
  /* 加载容器 */
  .loading-container {
    padding: 100rpx;
    text-align: center;
    color: #999;
  }
  
  /* 申请列表 */
  .application-list {
    padding: 20rpx;
  }
  
  /* 申请卡片 */
  .application-card {
    background: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
    overflow: hidden;
  }
  
  /* 卡片头部 */
  .card-header {
    padding: 20rpx 30rpx;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  }
  
  .user-info {
    display: flex;
    flex-direction: column;
    gap: 10rpx;
  }
  
  .username {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .phone {
    font-size: 26rpx;
    color: #666;
  }
  
  /* 状态徽章 */
  .status-badge {
    padding: 8rpx 20rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
  }
  
  .status-badge.pending {
    background: #fff3cd;
    color: #856404;
  }
  
  .status-badge.approved {
    background: #d4edda;
    color: #155724;
  }
  
  .status-badge.rejected {
    background: #f8d7da;
    color: #721c24;
  }
  
  .status-badge.cancelled {
    background: #e2e3e5;
    color: #383d41;
  }
  
  /* 卡片内容 */
  .card-content {
    padding: 30rpx;
  }
  
  .info-row {
    display: flex;
    margin-bottom: 20rpx;
    align-items: flex-start;
  }
  
  .info-row:last-child {
    margin-bottom: 0;
  }
  
  .info-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10rpx;
  }
  
  .info-label {
    font-size: 26rpx;
    color: #999;
    flex-shrink: 0;
    margin-right: 20rpx;
  }
  
  .info-value {
    font-size: 28rpx;
    color: #333;
    flex: 1;
    word-break: break-all;
  }
  
  .info-value.reason {
    line-height: 1.5;
    color: #666;
  }
  
  /* 请假类型徽章 */
  .type-badge {
    display: inline-block;
    padding: 6rpx 16rpx;
    border-radius: 12rpx;
    font-size: 26rpx;
    background: #f0f0f0;
    color: #666;
  }
  
  .type-badge.annual {
    background: #e3f2fd;
    color: #1976d2;
  }
  
  .type-badge.sick {
    background: #fce4ec;
    color: #c2185b;
  }
  
  .type-badge.personal {
    background: #f3e5f5;
    color: #7b1fa2;
  }
  
  .type-badge.compensatory {
    background: #e8f5e9;
    color: #388e3c;
  }
  
  .type-badge.maternity {
    background: #fff3e0;
    color: #f57c00;
  }
  
  .type-badge.marriage {
    background: #ffebee;
    color: #d32f2f;
  }
  
  /* 请假天数 */
  .days-number {
    font-size: 32rpx;
    font-weight: bold;
    color: #667eea;
    margin-right: 8rpx;
  }
  
  .days-unit {
    font-size: 26rpx;
    color: #999;
  }
  
  /* 卡片底部 */
  .card-footer {
    padding: 20rpx 30rpx;
    border-top: 1px solid #f0f0f0;
    display: flex;
    justify-content: flex-end;
    gap: 20rpx;
    background: #fafafa;
  }
  
  .btn-detail,
  .btn-audit {
    padding: 0 30rpx !important;
    font-size: 28rpx !important;
    height: 60rpx !important;
    line-height: 60rpx !important;
  }
  
  .btn-detail {
    background: #f5f5f5 !important;
    color: #666 !important;
  }
  
  .btn-audit {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    color: white !important;
  }
  
  /* 空状态 */
  .empty-container {
    padding: 200rpx 0;
    text-align: center;
  }
  
  .empty-icon {
    font-size: 120rpx;
    margin-bottom: 30rpx;
  }
  
  .empty-text {
    font-size: 30rpx;
    color: #999;
  }
  
  /* 动画效果 */
  .application-card {
    animation: slideUp 0.3s ease-out;
  }
  
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20rpx);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }