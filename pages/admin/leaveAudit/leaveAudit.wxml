<!--pages/admin/leaveAudit/leaveAudit.wxml-->
<view class="leave-audit-page">
  <!-- 顶部标题 -->
  <view class="page-header">
    <text class="page-title">请假审核管理</text>
    <button 
      class="batch-btn" 
      size="mini"
      wx:if="{{activeTab === 'pending' && applications.length > 0}}"
      bindtap="batchApprove"
    >
      批量通过
    </button>
  </view>

  <!-- 标签栏 -->
  <view class="tabs">
    <view 
      class="tab-item {{activeTab === tab.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-tab="{{tab.key}}"
      bindtap="switchTab"
    >
      <text>{{tab.title}}</text>
      <text class="tab-count" wx:if="{{tab.count > 0}}">({{tab.count}})</text>
    </view>
  </view>

  <!-- 加载提示 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <!-- 申请列表 -->
  <view wx:elif="{{applications.length > 0}}" class="application-list">
    <view class="application-card" wx:for="{{applications}}" wx:key="id">
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="user-info">
          <text class="username">{{item.username}}</text>
          <text class="phone">{{item.phone}}</text>
        </view>
        <view class="status-badge {{item.status}}">
          <text wx:if="{{item.status === 'pending'}}">待审核</text>
          <text wx:elif="{{item.status === 'approved'}}">已通过</text>
          <text wx:elif="{{item.status === 'rejected'}}">已拒绝</text>
          <text wx:else>已取消</text>
        </view>
      </view>

      <!-- 卡片内容 -->
      <view class="card-content">
        <view class="info-row">
          <view class="info-item">
            <text class="info-label">请假类型</text>
            <view class="info-value type-badge {{item.type_code}}">
              {{item.type_name}}
            </view>
          </view>
          <view class="info-item">
            <text class="info-label">请假天数</text>
            <view class="info-value">
              <text class="days-number">{{item.leave_days}}</text>
              <text class="days-unit">天</text>
            </view>
          </view>
        </view>
        
        <view class="info-row">
          <text class="info-label">请假日期：</text>
          <text class="info-value">{{item.dateRange}}</text>
        </view>
        
        <view class="info-row">
          <text class="info-label">请假原因：</text>
          <text class="info-value reason">{{item.reason}}</text>
        </view>
        
        <view class="info-row">
          <text class="info-label">申请时间：</text>
          <text class="info-value">{{item.formatCreateTime}}</text>
        </view>
        
        <!-- 已审批的显示审批信息 -->
        <block wx:if="{{item.status !== 'pending'}}">
          <view class="info-row">
            <text class="info-label">审批时间：</text>
            <text class="info-value">{{item.formatApproveTime}}</text>
          </view>
          <view class="info-row" wx:if="{{item.approve_remark}}">
            <text class="info-label">审批备注：</text>
            <text class="info-value">{{item.approve_remark}}</text>
          </view>
        </block>
      </view>

      <!-- 操作按钮 -->
      <view class="card-footer">
        <button 
          class="btn-detail" 
          size="mini"
          data-index="{{index}}"
          bindtap="viewDetail"
        >
          查看详情
        </button>
        <button 
          wx:if="{{item.status === 'pending'}}"
          class="btn-audit" 
          size="mini"
          type="primary"
          data-index="{{index}}"
          bindtap="showAuditDialog"
        >
          审批
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-container">
    <view class="empty-icon">📭</view>
    <text class="empty-text">
      暂无{{activeTab === 'pending' ? '待审核' : activeTab === 'approved' ? '已通过' : '已拒绝'}}的请假申请
    </text>
  </view>
</view>