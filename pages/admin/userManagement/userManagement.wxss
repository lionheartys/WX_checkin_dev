.user-management {
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  .header {
    background: #1890ff;
    color: white;
    padding: 30rpx;
    text-align: center;
  }
  
  .title {
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .search-bar {
    display: flex;
    padding: 20rpx;
    background: white;
    border-bottom: 1rpx solid #e8e8e8;
  }
  
  .search-input {
    flex: 1;
    height: 70rpx;
    padding: 0 20rpx;
    background: #f5f5f5;
    border-radius: 8rpx;
    font-size: 28rpx;
  }
  
  .search-btn {
    margin-left: 20rpx;
    padding: 0 30rpx;
    height: 70rpx;
    line-height: 70rpx;
    background: #1890ff;
    color: white;
    border-radius: 8rpx;
    font-size: 28rpx;
  }
  
  .user-list {
    padding: 20rpx;
  }
  
  .user-card {
    background: white;
    border-radius: 12rpx;
    padding: 25rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  }
  
  .user-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .user-basic {
    display: flex;
    align-items: center;
    gap: 15rpx;
  }
  
  .username {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .role-tag {
    padding: 4rpx 12rpx;
    border-radius: 6rpx;
    font-size: 22rpx;
  }
  
  .role-admin {
    background: #fff2e8;
    color: #fa541c;
  }
  
  .role-staff {
    background: #e6f7ff;
    color: #1890ff;
  }
  
  .status-tag {
    padding: 6rpx 16rpx;
    border-radius: 8rpx;
    font-size: 24rpx;
  }
  
  .status-approved {
    background: #f6ffed;
    color: #52c41a;
  }
  
  .status-pending {
    background: #fff7e6;
    color: #fa8c16;
  }
  
  .status-disabled {
    background: #fff1f0;
    color: #ff4d4f;
  }
  
  .info-row {
    display: flex;
    margin-bottom: 12rpx;
  }
  
  .label {
    color: #999;
    width: 140rpx;
    font-size: 26rpx;
  }
  
  .value {
    color: #333;
    flex: 1;
    font-size: 26rpx;
  }
  
  .actions {
    display: flex;
    gap: 20rpx;
    margin-top: 20rpx;
  }
  
  .btn-disable,
  .btn-enable,
  .btn-detail {
    flex: 1;
    height: 60rpx;
    line-height: 60rpx;
    text-align: center;
    border-radius: 8rpx;
    font-size: 26rpx;
    border: none;
  }
  
  .btn-disable {
    background: #ff4d4f;
    color: white;
  }
  
  .btn-enable {
    background: #52c41a;
    color: white;
  }
  
  .btn-detail {
    background: #f0f0f0;
    color: #666;
  }
  
  .empty {
    padding: 100rpx;
    text-align: center;
    color: #999;
  }