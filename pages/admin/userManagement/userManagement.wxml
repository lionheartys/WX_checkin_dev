<view class="user-management">
  <view class="header">
    <text class="title">用户管理</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" 
           placeholder="搜索用户名或手机号" 
           value="{{searchKey}}"
           bindinput="onSearchInput"
           bindconfirm="onSearch"/>
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- 用户列表 -->
  <view class="user-list">
    <view wx:for="{{userList}}" wx:key="id" class="user-card">
      <view class="user-header">
        <view class="user-basic">
          <text class="username">{{item.username}}</text>
          <text class="role-tag role-{{item.role}}">
            {{item.role === 'admin' ? '管理员' : '员工'}}
          </text>
        </view>
        <text class="status-tag status-{{item.status}}">
          {{statusMap[item.status]}}
        </text>
      </view>
      
      <view class="user-info">
        <view class="info-row">
          <text class="label">手机号：</text>
          <text class="value">{{item.phone}}</text>
        </view>
        <view class="info-row">
          <text class="label">公司ID：</text>
          <text class="value">{{item.company_id}}</text>
        </view>
        <view class="info-row">
          <text class="label">注册时间：</text>
          <text class="value">{{item.created_at}}</text>
        </view>
      </view>
      
      <view class="actions">
        <button wx:if="{{item.status === 'approved'}}" 
                class="btn-disable" 
                data-id="{{item.id}}" 
                bindtap="disableUser">
          禁用
        </button>
        <button wx:if="{{item.status === 'disabled'}}" 
                class="btn-enable" 
                data-id="{{item.id}}" 
                bindtap="enableUser">
          启用
        </button>
        <button class="btn-detail" 
                data-id="{{item.id}}" 
                bindtap="viewDetail">
          详情
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{userList.length === 0}}" class="empty">
    <text>暂无用户数据</text>
  </view>
</view>