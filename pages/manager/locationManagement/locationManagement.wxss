/* pages/admin/locationManagement/locationManagement.wxss */
.location-page {
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  /* 顶部操作栏 */
  .header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: white;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .add-btn {
    background: rgba(255, 255, 255, 0.2) !important;
    color: white !important;
    border: 1rpx solid rgba(255, 255, 255, 0.3) !important;
    padding: 0 24rpx !important;
    height: 60rpx !important;
    line-height: 60rpx !important;
    font-size: 28rpx !important;
    border-radius: 30rpx !important;
  }
  
  .add-btn:active {
    background: rgba(255, 255, 255, 0.3) !important;
  }
  
  /* 加载容器 */
  .loading-container {
    padding: 100rpx;
    text-align: center;
    color: #999;
  }
  
  /* 打卡地列表 */
  .location-list {
    padding: 20rpx;
  }
  
  /* 打卡地卡片 */
  .location-card {
    background: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
    overflow: hidden;
    animation: slideUp 0.3s ease-out;
  }
  
  /* 卡片头部 */
  .card-header {
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  }
  
  .location-info {
    display: flex;
    flex-direction: column;
    gap: 10rpx;
  }
  
  .location-name {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .project-name {
    font-size: 26rpx;
    color: #666;
  }
  
  .status-badge {
    padding: 8rpx 20rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
  }
  
  .status-badge.active {
    background: #d4edda;
    color: #155724;
  }
  
  .status-badge.inactive {
    background: #f8d7da;
    color: #721c24;
  }
  
  /* 卡片内容 */
  .card-content {
    padding: 30rpx;
  }
  
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20rpx;
  }
  
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 10rpx;
  }
  
  .info-item .label {
    font-size: 26rpx;
    color: #999;
  }
  
  .info-item .value {
    font-size: 28rpx;
    color: #333;
  }
  
  .info-item .coordinate {
    font-size: 24rpx;
    color: #666;
    font-family: monospace;
  }
  
  /* 操作按钮 */
  .card-actions {
    padding: 20rpx 30rpx;
    border-top: 1rpx solid #f0f0f0;
    display: flex;
    gap: 20rpx;
    background: #fafafa;
  }
  
  .action-btn {
    flex: 1;
    height: 60rpx !important;
    line-height: 60rpx !important;
    font-size: 26rpx !important;
    border-radius: 8rpx !important;
  }
  
  .action-btn.view {
    background: #e3f2fd !important;
    color: #1976d2 !important;
  }
  
  .action-btn.edit {
    background: #f3e5f5 !important;
    color: #7b1fa2 !important;
  }
  
  .action-btn.enable {
    background: #e8f5e9 !important;
    color: #388e3c !important;
  }
  
  .action-btn.disable {
    background: #fff3cd !important;
    color: #856404 !important;
  }
  
  .action-btn.delete {
    background: #ffebee !important;
    color: #d32f2f !important;
  }
  
  /* 空状态 */
  .empty-container {
    padding: 200rpx 40rpx;
    text-align: center;
  }
  
  .empty-icon {
    font-size: 120rpx;
    margin-bottom: 30rpx;
  }
  
  .empty-text {
    font-size: 30rpx;
    color: #999;
    margin-bottom: 40rpx;
    display: block;
  }
  
  .empty-btn {
    width: 300rpx !important;
    height: 80rpx !important;
    line-height: 80rpx !important;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    color: white !important;
    border-radius: 40rpx !important;
    font-size: 30rpx !important;
  }
  
  /* 弹窗 */
  .modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
  }
  
  .modal-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 700rpx;
    max-height: 80vh;
    background: white;
    border-radius: 20rpx;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    animation: scaleIn 0.3s ease;
  }
  
  /* 弹窗头部 */
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .modal-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
  
  .modal-close {
    font-size: 48rpx;
    color: #999;
    line-height: 1;
    padding: 0 10rpx;
  }
  
  /* 弹窗内容 */
  .modal-body {
    flex: 1;
    padding: 30rpx;
    overflow-y: auto;
    max-height: 60vh;
  }
  
  .form-item {
    margin-bottom: 30rpx;
  }
  
  .form-label {
    display: block;
    font-size: 28rpx;
    color: #666;
    margin-bottom: 16rpx;
  }
  
  .form-input {
    width: 100%;
    height: 80rpx;
    padding: 0 20rpx;
    background: #f8f9fa;
    border: 1rpx solid #e0e0e0;
    border-radius: 12rpx;
    font-size: 30rpx;
    box-sizing: border-box;
  }
  
  .picker-value {
    padding: 0 20rpx;
    height: 80rpx;
    line-height: 80rpx;
    background: #f8f9fa;
    border: 1rpx solid #e0e0e0;
    border-radius: 12rpx;
    font-size: 30rpx;
    color: #333;
  }
  
  /* 经纬度输入 */
  .location-input {
    display: flex;
    gap: 10rpx;
    align-items: center;
  }
  
  .coordinate-input {
    flex: 1;
  }
  
  .location-btn {
    flex-shrink: 0;
    padding: 0 20rpx !important;
    height: 80rpx !important;
    line-height: 80rpx !important;
    background: #667eea !important;
    color: white !important;
    font-size: 26rpx !important;
    border-radius: 12rpx !important;
  }
  
  /* 弹窗底部 */
  .modal-footer {
    display: flex;
    gap: 20rpx;
    padding: 30rpx;
    border-top: 1rpx solid #f0f0f0;
  }
  
  .modal-btn {
    flex: 1;
    height: 80rpx;
    border-radius: 40rpx;
    font-size: 30rpx;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-btn.cancel {
    background: #f5f5f5;
    color: #666;
  }
  
  .modal-btn.confirm {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }
  
  /* 动画效果 */
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20rpx);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
  }