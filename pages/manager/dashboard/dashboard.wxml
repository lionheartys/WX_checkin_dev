<view class="manager-dashboard">
  <!-- 顶部信息栏 -->
  <view class="header">
    <view class="title">项目管理员控制台</view>
    <view class="user-info">
      <text>{{userInfo.username}}</text>
      <text class="logout" bindtap="logout">退出</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="statistics">
    <view class="stat-card">
      <view class="stat-value">{{statistics.todayCheckins}}</view>
      <view class="stat-label">今日打卡</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{statistics.abnormalToday}}</view>
      <view class="stat-label">今日异常</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{statistics.pendingMakeup}}</view>
      <view class="stat-label">待审核补卡</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{statistics.pendingLeave}}</view>
      <view class="stat-label">待审核请假</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{statistics.pendingEntry}}</view>
      <view class="stat-label">待审批入场</view>
    </view>
  </view>

  <!-- 功能模块 -->
  <view class="modules">
    <view class="module-card" bindtap="goToMakeupAudit">
      <view class="module-icon">✏️</view>
      <view class="module-name">补卡审核</view>
      <view class="module-badge" wx:if="{{statistics.pendingMakeup > 0}}">
        {{statistics.pendingMakeup}}
      </view>
    </view>
    
    <view class="module-card" bindtap="goToLeaveAudit">
      <view class="module-icon">📋</view>
      <view class="module-name">请假审核</view>
      <view class="module-badge" wx:if="{{statistics.pendingLeave > 0}}">
        {{statistics.pendingLeave}}
      </view>
    </view>
    
    <view class="module-card" bindtap="goToCheckinRecords">
      <view class="module-icon">📊</view>
      <view class="module-name">打卡记录</view>
    </view>

    <view class="module-card" bindtap="goToLocationManagement">
      <view class="module-icon">📍</view>
      <view class="module-name">打卡地管理</view>
    </view>

    <view class="module-card" bindtap="goToProjectManagement">
      <view class="module-icon">📁</view>
      <view class="module-name">项目管理</view>
    </view>

    <view class="module-card" bindtap="goToEntryApproval">
      <view class="module-icon">🎫</view>
      <view class="module-name">入场审批</view>
      <view class="module-badge" wx:if="{{statistics.pendingEntry > 0}}" style="background-color: #ff5722;">
        {{statistics.pendingEntry}}
      </view>
    </view>
    
    <view class="module-card" bindtap="goToStatistics">
      <view class="module-icon">📈</view>
      <view class="module-name">数据统计</view>
    </view>
  </view>
</view>
