/* pages/admin/dashboard/dashboard.wxss */
.admin-dashboard {
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  .header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 40rpx 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .user-info {
    display: flex;
    align-items: center;
    gap: 20rpx;
    font-size: 28rpx;
  }
  
  .logout {
    color: #ffd700;
    text-decoration: underline;
  }
  
  .statistics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20rpx;
    padding: 30rpx;
    margin-top: -40rpx;
  }
  
  .stat-card {
    background: white;
    border-radius: 16rpx;
    padding: 30rpx;
    text-align: center;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  }
  
  .stat-value {
    font-size: 48rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 10rpx;
  }
  
  .stat-label {
    font-size: 24rpx;
    color: #999;
  }
  
  .modules {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20rpx;
    padding: 0 30rpx 30rpx;
  }
  
  .module-card {
    background: white;
    border-radius: 16rpx;
    padding: 40rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
    position: relative;
  }
  
  .module-icon {
    font-size: 60rpx;
    margin-bottom: 20rpx;
  }
  
  .module-name {
    font-size: 28rpx;
    color: #333;
  }
  
  .module-badge {
    position: absolute;
    top: 20rpx;
    right: 20rpx;
    background: #ff4444;
    color: white;
    border-radius: 20rpx;
    padding: 4rpx 16rpx;
    font-size: 24rpx;
    min-width: 40rpx;
    text-align: center;
  }