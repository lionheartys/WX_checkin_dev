<view class="container">
  <view class="header">
    <image class="logo" src="../../images/logo.jpg"></image>
    <text class="title">企业打卡系统</text>
  </view>

  <view class="form">
    <view class="input-group">
      <text class="label">用户名</text>
      <input class="input" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput"/>
    </view>
    
    <view class="input-group">
      <text class="label">手机号</text>
      <input class="input" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput"/>
    </view>
  </view>

  <view class="buttons">
    <button class="btn-primary" bindtap="login" disabled="{{loading}}">
      {{loading ? '登录中...' : '登录'}}
    </button>
    <button class="btn-secondary" bindtap="register">注册新用户</button>
  </view>
</view>