<view class="container">
  <view class="header">
    <image class="logo" src="../../images/logo.png"></image>
    <text class="title">企业打卡系统</text>
  </view>

  <!-- 登录表单 -->
  <view class="form" wx:if="{{!isRegister}}">
    <view class="input-group">
      <text class="label">用户名/手机号</text>
      <input class="input" placeholder="请输入用户名或手机号" value="{{username}}" bindinput="onUsernameInput"/>
    </view>
    
    <view class="input-group">
      <text class="label">密码</text>
      <input class="input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput"/>
    </view>
  </view>

  <!-- 注册表单 -->
  <view class="form" wx:if="{{isRegister}}">
    <view class="input-group">
      <text class="label">用户名</text>
      <input class="input" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput"/>
    </view>
    
    <view class="input-group">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput"/>
    </view>

    <view class="input-group">
      <text class="label">密码</text>
      <input class="input" type="password" placeholder="请输入密码（至少6位）" value="{{password}}" bindinput="onPasswordInput"/>
    </view>

    <view class="input-group">
      <text class="label">确认密码</text>
      <input class="input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput"/>
    </view>

    <view class="input-group">
    <text class="label">公司</text>
      <picker mode="selector" range="{{companyNameList}}" value="{{companyIndex}}" bindchange="onCompanyChange">
        <view class="input picker-display">
          {{ companyNameList.length ? companyNameList[companyIndex] : '请选择公司' }}
        </view>
      </picker>
  </view>

    <view class="input-group">
      <text class="label">角色</text>
      <picker mode="selector" range="{{roles}}" value="{{roleIndex}}" bindchange="onRoleChange">
        <view class="input picker-display">{{roles[roleIndex]}}</view>
      </picker>
    </view>

    <view class="input-group">
      <text class="label">设备ID</text>
      <view class="input input-static selectable">{{deviceId}}</view>
      <button class="btn-copy" size="mini" bindtap="copyDeviceId">复制</button>
    </view>

  </view>

  <view class="buttons">
    <button class="btn-primary" bindtap="{{isRegister ? 'register' : 'login'}}" disabled="{{loading}}">
      {{loading ? '处理中...' : (isRegister ? '注册' : '登录')}}
    </button>
    <button class="btn-secondary" bindtap="toggleMode">
      {{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}
    </button>
  </view>
</view>