.container {
    padding: 40rpx;
    min-height: 100vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .header {
    margin: 100rpx 0 80rpx;
    text-align: center;
  }
  
  .logo {
    width: 120rpx;
    height: 120rpx;
    border-radius: 20rpx;
    margin-bottom: 20rpx;
  }
  
  .title {
    color: #fff;
    font-size: 48rpx;
    font-weight: bold;
  }
  
  .form {
    width: 100%;
    margin-bottom: 60rpx;
  }
  
  .input-group {
    margin-bottom: 30rpx;
  }
  
  .label {
    display: block;
    color: #fff;
    font-size: 28rpx;
    margin-bottom: 10rpx;
  }
  
  .input {
    width: 100%;
    height: 80rpx;
    background: rgba(255, 255, 255, 0.1);
    border: 1rpx solid rgba(255, 255, 255, 0.2);
    border-radius: 10rpx;
    padding: 0 20rpx;
    color: #fff;
    font-size: 30rpx;
  }
  
  .input::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }
  
  .buttons {
    width: 100%;
  }
  
  .btn-primary, .btn-secondary {
    width: 100%;
    height: 90rpx;
    margin-bottom: 20rpx;
    border-radius: 45rpx;
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .btn-primary {
    background: #1890ff;
    color: #fff;
  }
  
  .btn-secondary {
    background: transparent;
    color: #fff;
    border: 1rpx solid rgba(255, 255, 255, 0.3);
  }