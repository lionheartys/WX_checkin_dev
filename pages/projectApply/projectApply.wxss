page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}
.page { position: relative; min-height: 100vh; padding-bottom: 140rpx; }
.header-bg {
  position: absolute; top: 0; left: 0; right: 0; height: 360rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-bottom-left-radius: 50rpx; border-bottom-right-radius: 50rpx; z-index: 0;
}
.form-card {
  position: relative; background: #fff; margin: 40rpx 30rpx 0; border-radius: 24rpx;
  padding: 28rpx 26rpx; box-shadow: 0 10rpx 40rpx rgba(0,0,0,.08); z-index: 1;
}
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 22rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.form-item:last-child { border-bottom: none; }
.form-item.column { flex-direction: column; align-items: stretch; gap: 16rpx; }
.item-left { display: flex; flex-direction: column; }
.item-label { font-size: 30rpx; color: #2c3e50; font-weight: 700; }
.item-desc { font-size: 22rpx; color: #9aa0a6; margin-top: 8rpx; }
.picker-value { min-width: 300rpx; text-align: right; font-size: 28rpx; color: #2c3e50; }
.picker-value.small { min-width: 180rpx; }
.picker-value.placeholder { color: #adb5bd; }
.datetime-row { display: flex; gap: 16rpx; }
.tips { margin-top: 10rpx; font-size: 22rpx; color: #f59e0b; }

.textarea-wrap { position: relative; background: #f8f9fa; border-radius: 16rpx; padding: 16rpx; }
.reason-textarea {
  width: 100%; min-height: 140rpx; font-size: 28rpx; color: #2c3e50; line-height: 1.6;
}
.counter {
  position: absolute; right: 16rpx; bottom: 12rpx; font-size: 22rpx; color: #9aa0a6;
}

.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx 30rpx env(safe-area-inset-bottom);
  background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,.2) 20%, rgba(255,255,255,.8) 60%, #fff 100%);
  backdrop-filter: blur(6px); box-shadow: 0 -6rpx 20rpx rgba(0,0,0,.06);
}
.submit-btn {
  width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; font-size: 30rpx; font-weight: 700; border: none;
}
.bottom-decoration { height: 80rpx; }
